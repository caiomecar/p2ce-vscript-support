{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/editors/code"
      ],
      "outFiles": [
        "${workspaceFolder}/editors/code/out/**/*.js"
      ],
      "autoAttachChildProcesses": true,
      "env": {
        "P2CE_VSCRIPT_LS_DEV": "1",
        "RUST_BACKTRACE": "1"
      },
      "preLaunchTask": "cargo build",
    },
    {
      "name": "Attach to Rust Server",
      "type": "lldb",
      "request": "attach",
      "program": "${workspaceFolder}/target/debug/p2ce-vscript-ls",
      "stopOnEntry": false
    }
  ]
}