{
  "name": "tf2-vscript-support",
  "displayName": "TF2 VScript Support",
  "description": "Language Server for TF2 VScript",
  "publisher": "ocet247",
  "icon": "logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ocet247/tf2-vscript-support"
  },
  "version": "3.0.2",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "scripts": {
    "build-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=node20",
    "build": "npm run build-base -- --sourcemap",
    "build-release": "npm run build-base -- --minify",
    "watch": "npm run build-base -- --sourcemap --watch",
    "lint": "eslint ./src",
    "lint:fix": "npm run lint -- --fix",
    "package": "npm run build-release && vsce package"
  },
  "dependencies": {
    "glob": "^11.0.0",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.19.27",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.5",
    "eslint": "^9.13.0",
    "mocha": "^10.3.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "tf2vscript",
        "aliases": [
          "TF2VScript"
        ],
        "extensions": [
          ".nut"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./logo.png",
          "dark": "./logo.png"
        }
      },
      {
        "id": "sqDoc"
      }
    ],
    "grammars": [
      {
        "language": "tf2vscript",
        "scopeName": "source.squirrel",
        "path": "./syntaxes/squirrel.tmLanguage.json"
      },
      {
        "language": "sqDoc",
        "scopeName": "source.sqDoc",
        "path": "./syntaxes/sqDoc.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "tf2vscript.selectTF2Root",
        "title": "Select TF2 Root Directory",
        "category": "TF2 VScript"
      }
    ],
    "configuration": [
      {
        "title": "TF2 VScript",
        "properties": {
          "tf2vscript.tf2Root": {
            "type": "string",
            "default": "",
            "description": "Path to your Team Fortress 2 installation directory."
          }
        }
      }
    ]
  }
}