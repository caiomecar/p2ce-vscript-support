{
  "name": "p2ce-vscript-support",
  "displayName": "P2CE VScript Support",
  "description": "Language Server for P2CE VScript",
  "publisher": "caiomc",
  "license": "GPL-3.0-only",
  "icon": "logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ocet247/tf2-vscript-support"
  },
  "version": "3.2.3",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "p2",
    "p2ce",
    "strata",
    "squirrel",
    "VScript"
  ],
  "scripts": {
    "build-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=node20",
    "build": "npm run build-base -- --sourcemap",
    "build-release": "npm run build-base -- --minify",
    "watch": "npm run build-base -- --sourcemap --watch",
    "lint": "eslint ./src",
    "lint:fix": "npm run lint -- --fix",
    "package": "npm run build-release && vsce package"
  },
  "dependencies": {
    "glob": "^11.0.0",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.19.27",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.5",
    "eslint": "^9.13.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^4.1.5"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "p2ce_vscript",
        "aliases": [
          "VScript"
        ],
        "extensions": [
          ".nut"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./fileicon.png",
          "dark": "./fileicon.png"
        }
      },
      {
        "id": "sqDoc"
      }
    ],
    "grammars": [
      {
        "language": "p2ce_vscript",
        "scopeName": "source.squirrel",
        "path": "./syntaxes/squirrel.tmLanguage.json"
      },
      {
        "language": "sqDoc",
        "scopeName": "source.sqDoc",
        "path": "./syntaxes/sqDoc.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "p2ce_vscript.selectTF2Root",
        "title": "Select TF2 Root Directory",
        "category": "P2CE VScript"
      }
    ],
    "configuration": [
      {
        "title": "P2CE VScript",
        "properties": {
          "p2ce_vscript.tf2RootPath": {
            "type": "string",
            "default": "",
            "description": "Path to your Team Fortress 2 installation directory."
          },
          "p2ce_vscript.unusedVariables": {
            "type": "string",
            "default": "hint",
            "enum": [
              "warn",
              "hint",
              "off"
            ],
            "description": "Controls how unused variables are reported."
          },
          "p2ce_vscript.unreachableCode": {
            "type": "string",
            "default": "warn",
            "enum": [
              "warn",
              "hint",
              "off"
            ],
            "description": "Controls how unreachable code is reported."
          },
          "p2ce_vscript.inlayHints.typeHints": {
            "type": "boolean",
            "default": true,
            "description": "Show type hints for variables and parameters."
          },
          "p2ce_vscript.inlayHints.enumMemberValue": {
            "type": "boolean",
            "default": true,
            "description": "Show value hints for auto-assigned enum member value."
          },
          "p2ce_vscript.inlayHints.parameterHints": {
            "type": "boolean",
            "default": true,
            "description": "Show parameter name hints on function calls."
          },
          "p2ce_vscript.workspaceDiagnostics": {
            "type": "boolean",
            "default": false,
            "description": "Enable workspace-wide diagnostics. May be slow for large workspaces."
          }
        }
      }
    ]
  }
}