{
  "compilerOptions": {
    "target": "ES2024",
    "lib": [
      "ESNext"
    ],
    "module": "node16",
    "moduleResolution": "node16",
    "declaration": true,
    "sourceMap": true,
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true
  }
}